<!DOCTYPE html>
<html lang="en">

<head>
    <title>AZ Functions OnPrem</title>
    <%- include("./partials/header.ejs") -%>
</head>

<body>
    <main class="container">
        <hgroup>
            <h1>AZ Functions OnPrem</h1>
            <p>Self-hosted integrations. Invoke an action below or hit <code>GET /action/&lt;name&gt;</code> directly.</p>
        </hgroup>

        <% if (actions.length === 0) { %>
            <article>
                <p>No actions registered. Define one with <code>defineAction(...)</code> in <code>src/actions/</code> and import it from <code>src/actions/index.ts</code>.</p>
            </article>
        <% } %>

        <% actions.forEach(function(action) {
            const kind = action.stream ? "stream" : action.steps ? "sequence" : "handler";
        %>
            <article>
                <header style="display: flex; align-items: baseline; gap: 1rem; flex-wrap: wrap; margin-bottom: 0.5rem;">
                    <strong style="flex: 1; min-width: 10rem;"><%= action.name %></strong>
                    <small style="display: flex; gap: 0.35rem; flex-wrap: wrap;">
                        <kbd><%= kind %></kbd>
                        <% if (action.schedule) { %><kbd>cron: <%= action.schedule %></kbd><% } %>
                        <% if (action.timeoutMs) { %><kbd>timeout: <%= action.timeoutMs %>ms</kbd><% } %>
                        <% if (action.auth) { %><kbd>auth: <%= action.auth %></kbd><% } %>
                        <% if (action.onSuccess) { %><kbd>hook</kbd><% } %>
                    </small>
                    <button type="button" data-action="<%= action.name %>" style="margin: 0;">Run</button>
                </header>
                <p style="margin: 0;"><%= action.description %></p>
                <div class="action-output-wrapper" data-output-wrapper-for="<%= action.name %>" hidden>
                    <button type="button" class="action-output-close" data-close-output="<%= action.name %>" aria-label="Close output">&times;</button>
                    <pre class="action-output" data-output-for="<%= action.name %>" aria-live="polite" tabindex="0"></pre>
                </div>
            </article>
        <% }) %>
    </main>
    <%- include("./partials/footer.ejs") -%>
</body>

</html>
