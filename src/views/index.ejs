<!DOCTYPE html>
<html lang="en">

<head>
    <title>az-functions-onprem</title>
    <%- include("./partials/header.ejs") -%>
</head>

<body>
    <main class="container">
        <hgroup>
            <h1>az-functions-onprem</h1>
            <p>Self-hosted integrations. Invoke an action below or hit <code>/action/&lt;name&gt;</code> directly.</p>
        </hgroup>

        <% if (actions.length === 0) { %>
            <article>
                <p>No actions registered. Define one with <code>defineAction(...)</code> in <code>src/actions/</code> and import it from <code>src/actions/index.ts</code>.</p>
            </article>
        <% } %>

        <% actions.forEach(function(action) {
            const kind = action.stream ? "stream" : action.steps ? "sequence" : "handler";
            const lastRun = getLastRun(action.name);
            const methods = action.methods && action.methods.length ? action.methods : ["GET", "POST"];
            const postAllowed = methods.includes("POST");
            const actionTitleId = `action-${action.name}`;
            const outputId = `output-${action.name}`;
        %>
            <article class="action-card" aria-labelledby="<%= actionTitleId %>">
                <header class="action-card-header">
                    <div class="action-card-main">
                        <h2 id="<%= actionTitleId %>" class="action-title"><%= action.name %></h2>
                        <small class="action-meta">
                            <kbd><%= kind %></kbd>
                            <kbd>method: <%= methods.join("/") %></kbd>
                            <% if (action.schedule) { %><kbd>cron: <%= action.schedule %></kbd><% } %>
                            <% if (action.timeoutMs) { %><kbd>timeout: <%= action.timeoutMs %>ms</kbd><% } %>
                            <kbd>auth: <%= action.authLevel || "header" %></kbd>
                            <% if (action.concurrency) { %><kbd>concurrency: <%= action.concurrency %></kbd><% } %>
                            <% if (action.onSuccess) { %><kbd>hook</kbd><% } %>
                            <% if (lastRun) { %>
                                <kbd class="status-badge status-<%= lastRun.status %>">last: <%= lastRun.status %> <%= new Date(lastRun.at).toLocaleTimeString() %> (<%= lastRun.durationMs %>ms)</kbd>
                            <% } else { %>
                                <kbd>last: never</kbd>
                            <% } %>
                        </small>
                    </div>
                    <div class="action-run-controls" aria-label="Run <%= action.name %>">
                        <% methods.forEach(function(method) { %>
                            <button type="button" data-action="<%= action.name %>" data-method="<%= method %>" aria-label="Run <%= action.name %> with <%= method %>" aria-describedby="<%= outputId %>">Run <%= method %></button>
                        <% }) %>
                    </div>
                </header>
                <p class="action-description"><%= action.description %></p>
                <% if (postAllowed) { %>
                    <details class="request-body">
                        <summary>POST body</summary>
                        <textarea data-body-for="<%= action.name %>" spellcheck="false">{}</textarea>
                    </details>
                <% } %>
                <div class="action-output-wrapper" data-output-wrapper-for="<%= action.name %>" hidden>
                    <button type="button" class="action-output-close" data-close-output="<%= action.name %>" aria-label="Close output">&times;</button>
                    <pre id="<%= outputId %>" class="action-output" data-output-for="<%= action.name %>" aria-live="polite" tabindex="0"></pre>
                </div>
            </article>
        <% }) %>
    </main>
    <%- include("./partials/footer.ejs") -%>
</body>

</html>
